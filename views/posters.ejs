<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Posters &ndash; Grady Rueffer for CS Representative</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<%- include('partials/nav') %>

<div class="page-header">
  <div class="label"><span class="label-line"></span>Campaign Materials<span class="label-line"></span></div>
  <h1>Posters</h1>
  <p>Find these around Campus!</p>
</div>

<section class="posters-section">
  <!--
    HOW TO ADD A POSTER:
    1. Place your poster image (e.g. poster1.jpg) in public/images/
    2. Uncomment and update one of the .poster-card blocks below:
       - Update <img src="/images/your-file.jpg">
       - Update the poster name label
       - Update the download href to "/images/your-file.jpg"
  -->

  <div class="poster-grid">

    
    <div class="poster-card">
      <div class="poster-img">
        <img src="/images/GP1.png" alt="Can I Kahl On You" />
      </div>
      <div class="poster-info">
        <span class="poster-name">Can I Kahl On You</span>
        <a href="/images/GP1.png" download class="poster-download">&#8595; Download</a>
      </div>
    </div>
    <div class="poster-card">
      <div class="poster-img">
        <img src="/images/GP2.png" alt="Your Vote, Your Voice" />
      </div>
      <div class="poster-info">
        <span class="poster-name">Your Vote, Your Voice</span>
        <a href="/images/GP2.png" download class="poster-download">&#8595; Download</a>
      </div>
    </div>
    <div class="poster-card">
      <div class="poster-img">
        <img src="/images/GP3.png" alt="Debugging the Divide" />
      </div>
      <div class="poster-info">
        <span class="poster-name">Debugging the Divide</span>
        <a href="/images/GP3.png" download class="poster-download">&#8595; Download</a>
      </div>
    </div>

  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
